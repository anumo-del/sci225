    linkStyle 9 stroke-width:2px,stroke:orange; %% La validación del Token
    linkStyle 10 stroke-width:2px,stroke:green; %% El filtro de dominio

    %% Estilos de Nodos
    style Usuario fill:#f9f9f9,stroke:#333,stroke-width:2px;
    style Google_Apps_Script fill:#e1f5fe,stroke:#0277bd,stroke-width:2px;
